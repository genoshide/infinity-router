# Required: get a free key at https://openrouter.ai/keys
# Single key:
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Multiple keys (comma-separated) — recommended to avoid daily free-tier limits.
# Each key gets its own daily quota. Infinity-Router rotates through them during validation.
# OPENROUTER_API_KEY=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3
